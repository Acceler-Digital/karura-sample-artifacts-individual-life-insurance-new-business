#!/bin/bash
# git pre-commit フック(セキュリティ最終防衛線)。
# ステージ済みファイルを検査し、high(シークレット・資格情報・デナイリスト固有名詞)を
# 検出した場合はコミットをブロックする。medium は警告表示のみ。
#
# このフックを有効化するには、リポジトリ直下で一度だけ:
#   git config core.hooksPath .githooks
# (npm run prepare でも設定される)
#
# 緊急時の回避: git commit --no-verify(誤検知が確実な場合のみ)

if ! bash scripts/security-scan.sh --staged; then
  echo ""
  echo "⛔ コミットを中止しました: high レベルのセキュリティ懸念が含まれています。"
  echo "   修正後に再度コミットしてください。"
  echo "   誤検知が確実な場合のみ: git commit --no-verify"
  exit 1
fi
exit 0
